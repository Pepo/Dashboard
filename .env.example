# iCloud Zugangsdaten (für Kalender & Handy finden)
# App-spezifisches Passwort unter: https://appleid.apple.com → Sicherheit → App-spezifische Passwörter
ICLOUD_EMAIL=deine@email.com
ICLOUD_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Port des Servers (optional, Standard: 3000)
PORT=3000

# ntfy Push-Topic für "Handy klingeln"
# Einen geheimen, einzigartigen Namen wählen (kein Account nötig)
# App auf iPhone: https://ntfy.sh (kostenlos im App Store)
NTFY_TOPIC=dashboard-ring-dein-name-hier
